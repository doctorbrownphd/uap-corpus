{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pipeline: acquire",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "scripts/01_acquire.py",
        "--input",
        "${input:acquireInputPath}"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "pipeline: clean",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["scripts/02_clean.py"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "pipeline: embed",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["scripts/03_embed.py"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "pipeline: embed (force)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["scripts/03_embed.py", "--force"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "pipeline: run all (clean + embed)",
      "dependsOrder": "sequence",
      "dependsOn": ["pipeline: clean", "pipeline: embed"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "env: install dependencies",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "pip", "install", "-r", "requirements.txt"],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "env: create venv",
      "type": "shell",
      "command": "python3",
      "args": ["-m", "venv", ".venv"],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "data: show cleaning report",
      "type": "shell",
      "command": "cat",
      "args": ["data/interim/cleaning_report.txt"],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "data: profile cleaned dataset",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-c",
        "import pandas as pd; df = pd.read_parquet('data/interim/nuforc_clean.parquet'); print(f'Rows: {len(df):,}'); print(f'Date range: {df[\"event_dt\"].min()} to {df[\"event_dt\"].max()}'); print(f'States: {df[\"state\"].nunique()}'); print(f'Shapes: {df[\"shape_norm\"].nunique()}'); print(); print('Top 10 shapes:'); print(df['shape_norm'].value_counts().head(10).to_string()); print(); print('Top 10 states:'); print(df['state'].value_counts().head(10).to_string())"
      ],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "data: clean and rerun",
      "type": "shell",
      "command": "rm",
      "args": [
        "-f",
        "data/interim/nuforc_clean.parquet",
        "data/interim/drops.csv",
        "data/interim/cleaning_report.txt"
      ],
      "group": "none",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "tests: run all",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "pytest", "tests/", "-v"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "acquireInputPath",
      "type": "promptString",
      "description": "Path to source CSV (e.g. data/raw/scrubbed.csv)",
      "default": "data/raw/scrubbed.csv"
    }
  ]
}
